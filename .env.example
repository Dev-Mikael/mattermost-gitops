# =============================================================
# mattermost-gitops — Environment Configuration
# COPY THIS FILE TO .env AND FILL IN YOUR REAL VALUES
# .env is gitignored and MUST NEVER be committed
# =============================================================

# ----- Git & GitHub -----
GITHUB_USER=your-github-username
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=mattermost-gitops
GITHUB_BRANCH=main

# ----- Cluster -----
CLUSTER_NAME=production
# CLUSTER_TYPE: "kind" for local dev/test  |  "kubeadm" for real on-prem server
CLUSTER_TYPE=kubeadm

# ----- Networking -----
# Your server's public IP address (the machine running Kubernetes)
SERVER_IP=1.2.3.4
# Your domain name
DOMAIN=modumichael.me
# Email for Let's Encrypt TLS certificates
LETSENCRYPT_EMAIL=admin@modumichael.me

# ----- Secrets -----
# PostgreSQL database password (min 16 chars recommended)
DB_PASSWORD=change-me-to-a-strong-password-min16chars

# Optional: MetalLB IP range override (leave blank to auto-detect)
# For kubeadm: defaults to SERVER_IP/32 (single IP)
# For kind:    auto-detected from docker network
METALLB_IP_RANGE=
